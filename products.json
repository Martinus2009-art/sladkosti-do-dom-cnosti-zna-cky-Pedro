const products = YOUR_ORIGINAL_JSON;

const categoryMap = {
  "úvodná_stránka": "uvodna-stranka",
  "namíchej_si": "namiesaj-si",
  "pendreky_a_pásky": "pelendreky-a-pasky",
  "lékořice": "sladke-drievko",
  "lízátka_a_bonbóny": "lizanky-a-cukriky",
  "čokoládové_výrobky": "cokoladove-vyrobky",
  "čokoládové_tyčinky": "cokoladove-tycinky",
  "proteinové_tyčinky": "proteinove-tycinky",
  "směsi_a_suché_plody": "zmesi-a-suche-plody",
  "zdrava_vyziva": "zdrava-vyziva",
  "solené_výrobky": "solene-vyrobky",
  "lyo-sušené_ovoce": "lyo-susene-ovocie",
  "fini_-_želé_a_pendreky": "fini-zele-a-pendreky",
  "oplatky": "oblatky",
  "komprimát": "komprimat",
  "zele": "zele",
  "kysle": "kysle",
  "mix": "mix",
  "pelendreky": "pelendreky",
  "pasky": "pasky",
  "lizanky": "lizanky",
  "cokolada": "cokolada"
};

function normalizeText(str) {
  return String(str || "")
    .replace(/\s+/g, " ")
    .replace(/\n+/g, " ")
    .trim();
}

function slugify(str) {
  return normalizeText(str)
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .toLowerCase()
    .replace(/&/g, "-and-")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "")
    .replace(/-+/g, "-");
}

function getCategoryFromUrl(url) {
  try {
    const path = new URL(url).pathname.split("/").filter(Boolean);
    return path[0] || "nezaradene";
  } catch {
    return "nezaradene";
  }
}

const fixedProducts = products.map((p) => {
  const nameText = normalizeText(p?.name?.sk || "");
  const urlCategory = getCategoryFromUrl(p.url);

  const tags = Array.isArray(p.cat)
    ? [...new Set(
        p.cat
          .map(c => categoryMap[c] || slugify(c))
          .filter(Boolean)
      )]
    : [];

  // hlavná kategória z URL je najspoľahlivejšia
  const category = urlCategory;

  return {
    id: p.id,
    name: {
      sk: nameText
    },
    nameText,
    images: Array.isArray(p.images) ? p.images.filter(Boolean) : [],
    priceEUR: Number(p.priceEUR) || 0,
    url: p.url || "",
    category,
    tags
  };
});

console.log(JSON.stringify(fixedProducts, null, 2));
